{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Llm": {
    "Provider": "OpenAI",
    "OpenAI": {
      "ApiKey": "",
      "Model": "gpt-4o-mini"
    },
    "AzureOpenAI": {
      "Endpoint": "",
      "ApiKey": "",
      "DeploymentName": ""
    },
    "Anthropic": {
      "ApiKey": "",
      "Model": "claude-sonnet-4-6"
    }
  },

  "Security": {
    "ApiKey": ""
  },

  "Postgres": {
  "ConnectionString": ""
  },

  "Rag": {
    "Enabled": true,
    "DocumentsFolder": "documents",
    "ChunkSize": 800,
    "ChunkOverlap": 150,
    "EmbeddingModel": "text-embedding-3-small",
    "EmbeddingDimensions": 1536,
    "Qdrant": {
      "Host": "localhost",
      "Port": 6334,
      "CollectionName": "agent-platform-docs"
    }
  },

  "Telegram": {
  "Enabled": false,
  "BotToken": "",
  "AllowedUserIds": ""
  },

  "RateLimit": {
  "MaxRequestsPerWindow": 10,
  "WindowSeconds": 60
  },

  "_NOT": "ApiKey alanları BURAYA yazılmaz. Ortam değişkeni ile override edilir: Llm__OpenAI__ApiKey, Security__ApiKey (ASP.NET Core'un çift alt çizgi konfigürasyon kuralı). Bkz. docker-compose.yml ve README.md."
}
